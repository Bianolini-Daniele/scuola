<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="443.0" prefWidth="404.0" spacing="20.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="com.bianolini.es_7.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <Label fx:id="Risultato" alignment="CENTER" text="0">
      <font>
         <Font size="30.0" />
      </font>
   </Label>
   <HBox alignment="CENTER_RIGHT" prefHeight="60.0" prefWidth="360.0">
      <children>
         <Label prefHeight="40.0" prefWidth="200.0" text="Primo numero" />
         <TextField fx:id="a" prefHeight="40.0" prefWidth="200.0" promptText="inserisci un numero" text="1" />
      </children>
   </HBox>
   <HBox alignment="CENTER_RIGHT" prefHeight="60.0" prefWidth="360.0">
      <children>
         <Label prefHeight="40.0" prefWidth="200.0" text="Secondo numero" />
         <TextField fx:id="b" prefHeight="40.0" prefWidth="200.0" promptText="inserisci un numero" text="2" />
      </children>
   </HBox>
    <Button fx:id="Somma" onAction="#onHelloButtonClick" prefHeight="73.0" prefWidth="124.0" text="Somma" />
</VBox>
